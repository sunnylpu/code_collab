# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/collab-editor?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS — comma-separated allowed frontend origins
CLIENT_URL=http://localhost:5173

# Persistence — how often (ms) to save Yjs state to MongoDB
PERSIST_INTERVAL_MS=5000
